<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>Touch Welness App</title>
<link rel="manifest" href="manifest.json">
<link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-database-compat.js"></script>
<script src="DeviceSync.js"></script>

<style>
  :root { 
      --bg-body: #0f172a; --bg-panel: #1e293b; --border-line: #334155; 
      --text-main: #f8fafc; --text-muted: #94a3b8; 
      --accent: #38bdf8; --gold: #fbbf24; --green: #10b981; --red: #ef4444; --purple: #a855f7;
      --row-height: 75px; 
  }
  :root.light-theme {
      --bg-body: #f8fafc; --bg-panel: #ffffff; --border-line: #e2e8f0;
      --text-main: #0f172a; --text-muted: #64748b;
  }

  /* FIX ENORME SCROLL: Disattiva il ricaricamento trascinando verso il basso */
  html, body { overscroll-behavior-y: none; overscroll-behavior-x: none; }

  * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
  body { font-family: -apple-system, system-ui, Roboto, sans-serif; background: var(--bg-body); margin: 0; display: flex; flex-direction: column; height: 100vh; overflow: hidden; color: var(--text-main); transition: background 0.3s; }
  
  .app-header { background: var(--bg-body); padding: 15px; display: flex; justify-content: space-between; align-items: center; z-index: 20; border-bottom: 1px solid var(--border-line); box-shadow: 0 4px 15px rgba(0,0,0,0.4); flex-shrink: 0; padding-top: max(15px, env(safe-area-inset-top)); }
  .header-title { font-weight: 900; color: var(--gold); letter-spacing: 1px; font-size: 16px; text-transform: uppercase; }
  
  .view-container { flex: 1; position: relative; overflow: hidden; display: flex; flex-direction: column; padding-bottom: 70px; overscroll-behavior: none; }
  .app-view { display: none; flex: 1; overflow-y: auto; overflow-x: hidden; animation: fadeView 0.2s ease; flex-direction: column; position: relative; overscroll-behavior: none; }
  .app-view.active { display: flex; }
  @keyframes fadeView { from { opacity: 0; transform: scale(0.98); } to { opacity: 1; transform: scale(1); } }

  /* FIX CALENDARIO TAGLIATO */
  .date-ctrl { display: flex; align-items: center; gap: 5px; background: var(--bg-panel); padding: 5px; border-radius: 12px; border: 1px solid var(--border-line); justify-content: center; max-width: 100%; }
  .btn-arrow { background: var(--accent); color: #0f172a; border: none; padding: 6px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  input[type="date"] { border: none; background: transparent; color: var(--text-main); font-weight: 800; font-size: 14px; text-align: center; width: 135px; padding: 0; outline: none; color-scheme: dark; appearance: none; -webkit-appearance: none; flex-shrink: 0; }

  .grid-container { flex: 1; display: flex; gap: 15px; padding: 15px 5vw; overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth; }
  .grid-container::-webkit-scrollbar { display: none; }
  .colonna { flex: none; width: 85vw; background: var(--bg-panel); border-radius: 20px; border: 1px solid var(--border-line); height: fit-content; overflow: hidden; box-shadow: 0 5px 20px rgba(0,0,0,0.5); scroll-snap-align: center; margin-bottom: 20px; }
  .col-head { background: var(--bg-body); color: var(--text-main); padding: 15px; text-align: center; font-weight: 900; font-size: 14px; border-bottom: 2px solid var(--gold); position: sticky; top: 0; z-index: 2; text-transform: uppercase; }
  
  .time-row { display: flex; height: var(--row-height); border-bottom: 1px solid var(--border-line); }
  .time-lbl { width: 45px; background: rgba(0,0,0,0.2); display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: bold; color: var(--text-muted); border-right: 1px solid var(--border-line); }
  .slot { flex: 1; position: relative; transition: background 0.2s; }
  .slot:active { background: rgba(56, 189, 248, 0.05); }
  
  .slot.drag-over { background: rgba(56, 189, 248, 0.2) !important; border: 2px dashed var(--accent) !important; z-index: 10; box-shadow: inset 0 0 10px rgba(56,189,248,0.3); }

  .app-base { background: #e0f2fe; color: #0c4a6e; border-left: 5px solid var(--accent); width: calc(100% - 6px); position: absolute; left: 3px; padding: 8px 12px; font-size: 12px; overflow: hidden; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.3); display: flex; justify-content: space-between; align-items: flex-start; z-index: 5; transition: transform 0.2s; }
  .app-base.dragging { opacity: 0.8; transform: scale(0.95); z-index: 9999; }
  .app-base.eseguito-style { background: #dcfce7; color: #064e3b; border-left-color: var(--green); }
  
  .app-base.req-style { background: #f3e8ff; color: #581c87; border-left-color: var(--purple); animation: pulseReq 2s infinite; pointer-events: auto; cursor: pointer; }
  @keyframes pulseReq { 0% { box-shadow: 0 0 0 0 rgba(168, 85, 247, 0.4); } 70% { box-shadow: 0 0 0 6px rgba(168, 85, 247, 0); } 100% { box-shadow: 0 0 0 0 rgba(168, 85, 247, 0); } }
  
  .app-info-col { flex: 1; display: flex; flex-direction: column; pointer-events: none; }
  .app-base b { font-size: 14px; text-transform: uppercase; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: #0369a1; }
  .app-base.eseguito-style b { color: var(--green); }
  .app-base.req-style b { color: var(--purple); }

  .app-busy { background: rgba(0,0,0,0.1); width: 100%; height: 100%; position: absolute; top: 0; left: 0; border-left: 3px solid var(--border-line); z-index: 1; }
  .app-busy.req-busy { background: rgba(168, 85, 247, 0.1); border-left-color: var(--purple); }

  .btn-quick-eseg { background: white; border: 2px solid #bae6fd; border-radius: 50%; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; color: var(--accent); box-shadow: 0 2px 5px rgba(0,0,0,0.2); pointer-events: auto; }
  .app-base.eseguito-style .btn-quick-eseg { background: var(--green); color: white; border-color: var(--green); }

  .list-container { padding: 15px; display: flex; flex-direction: column; gap: 15px; }
  .app-card { background: var(--bg-panel); border: 1px solid var(--border-line); border-radius: 16px; padding: 20px; display: flex; flex-direction: column; gap: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.3); }
  .app-id { font-size: 12px; color: var(--accent); font-family: monospace; font-weight: bold; padding: 4px 8px; border: 1px dashed var(--accent); border-radius: 6px; display: inline-block; width: fit-content; }
  .app-actions { display: flex; gap: 8px; width: 100%; border-top: 1px solid var(--border-line); padding-top: 15px; justify-content: space-between; }
  .action-btn { flex:1; background: var(--bg-body); border: 1px solid var(--border-line); border-radius: 8px; padding: 12px; color: var(--text-muted); font-size: 11px; font-weight: bold; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 5px; text-align:center; transition:0.2s; }
  .action-btn.done { background: rgba(16, 185, 129, 0.1); color: var(--green); border-color: rgba(16, 185, 129, 0.3); }
  .action-btn.paid { background: rgba(251, 191, 36, 0.1); color: var(--gold); border-color: rgba(251, 191, 36, 0.3); }
  .action-btn.del { background: rgba(239, 68, 68, 0.1); color: var(--red); border-color: rgba(239, 68, 68, 0.3); flex: 0.4; }

  .iframe-container { width: 100%; height: 100%; border: none; display: block; background: var(--bg-body); }

  .padding-view { padding: 20px; }
  .card-box { background: var(--bg-panel); border-radius: 16px; padding: 20px; box-shadow: 0 5px 20px rgba(0,0,0,0.3); margin-bottom: 20px; border: 1px solid var(--border-line); }
  .card-box h2 { margin-top: 0; color: var(--gold); font-size: 16px; border-bottom: 1px solid var(--border-line); padding-bottom: 10px; margin-bottom: 15px; text-transform: uppercase; display:flex; align-items:center; gap:8px; }
  
  .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px; }
  .stat-card { padding: 15px 10px; text-align: center; background: var(--bg-body); border-radius: 12px; border: 1px solid var(--border-line); border-bottom: 4px solid var(--accent); }
  .stat-val { font-size: 20px; font-weight: 900; color: var(--text-main); margin: 5px 0; }
  .stat-lbl { font-size: 10px; color: var(--text-muted); font-weight: bold; text-transform: uppercase; }
  .info-text { font-size: 14px; color: var(--text-main); background: var(--bg-body); padding: 12px; border-radius: 8px; border: 1px solid var(--border-line); font-weight: bold; margin-bottom: 10px; }

  .theme-card { border: 2px solid var(--border-line); border-radius: 12px; padding: 15px; text-align:center; color: var(--text-main); background:var(--bg-body); flex:1; cursor: pointer; }
  
  .mobile-bottom-bar { display: flex; position: fixed; bottom: 0; left: 0; width: 100%; background: var(--bg-panel); border-top: 1px solid var(--border-line); z-index: 9000; justify-content: space-around; align-items: center; padding: 10px 0 calc(10px + env(safe-area-inset-bottom)); box-shadow: 0 -5px 20px rgba(0,0,0,0.5); }
  .mobile-bottom-bar div { display: flex; flex-direction: column; align-items: center; gap: 4px; color: var(--text-muted); font-size: 10px; font-weight: 800; text-transform: uppercase; cursor: pointer; transition: 0.2s; width:20%; text-align:center; }
  .mobile-bottom-bar div.active { color: var(--accent); }
  .mobile-bottom-bar i { font-size: 24px; }

  /* FIX TASTO PIÙ (+): Alzato a 115px per non coprire il menu */
  .mobile-fab { display: flex; position: fixed; bottom: 115px; right: 20px; width: 60px; height: 60px; border-radius: 50%; background: var(--accent); color: #0f172a; border: none; box-shadow: 0 5px 20px rgba(56, 189, 248, 0.5); align-items: center; justify-content: center; font-size: 32px; z-index: 9000; transition: 0.2s; }
  .mobile-fab:active { transform: scale(0.9); }

  .bottom-sheet { position: fixed; bottom: -100%; left: 0; right: 0; width: 100vw; height: 90vh; background: var(--bg-panel); border-radius: 24px 24px 0 0; z-index: 9999; box-shadow: 0 -10px 40px rgba(0,0,0,0.8); transition: bottom 0.3s cubic-bezier(0.4, 0, 0.2, 1); padding: 25px 20px 40px 20px; overflow-y: auto; display: flex; flex-direction: column; }
  .bottom-sheet.active { bottom: 0; }
  .drag-handle { width: 40px; height: 5px; background: var(--border-line); border-radius: 10px; margin: -10px auto 20px auto; }
  .mobile-backdrop { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 9998; backdrop-filter: blur(3px); }
  .bottom-sheet.active + .mobile-backdrop { display: block; }

  .form-group { margin-bottom: 12px; width: 100%; }
  .form-group label { display: block; font-size: 11px; font-weight: bold; color: var(--text-muted); text-transform: uppercase; margin-bottom: 6px; }
  .form-input { width: 100%; padding: 14px; border: 1px solid var(--border-line); border-radius: 10px; font-size: 14px; background: var(--bg-body); color: var(--text-main); outline:none; color-scheme: dark; }
  
  .btn-save { width: 100%; padding: 16px; background: var(--accent); color: #0f172a; border: none; border-radius: 12px; font-weight: 900; font-size: 14px; display: flex; align-items: center; justify-content: center; gap: 8px; cursor: pointer; }
  .btn-wa { background: rgba(16, 185, 129, 0.1) !important; color: var(--green) !important; border: 1px solid rgba(16, 185, 129, 0.3) !important; }
  .btn-del { background: rgba(239, 68, 68, 0.1) !important; color: var(--red) !important; border: 1px solid rgba(239, 68, 68, 0.3) !important; }
  .btn-outline { background: transparent !important; border: 1px solid var(--border-line) !important; color: var(--text-main) !important; }

  .switch-container { display: flex; align-items: center; justify-content: space-between; background: var(--bg-body); padding: 15px; border-radius: 10px; border: 1px solid var(--border-line); margin-top: 15px; }
  .switch { position: relative; display: inline-block; width: 50px; height: 28px; }
  .switch input { opacity: 0; width: 0; height: 0; }
  .slider { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background-color: var(--border-line); border-radius: 34px; transition: .3s; }
  .slider:before { position: absolute; content: ""; height: 20px; width: 20px; left: 4px; bottom: 4px; background-color: white; border-radius: 50%; transition: .3s; }
  input:checked + .slider { background-color: var(--green); }
  input:checked + .slider:before { transform: translateX(22px); }

  .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 10000; align-items: center; justify-content: center; padding: 15px; }
  .modal-box { background: var(--bg-panel); padding: 20px; border-radius: 20px; width: 100%; max-height: 80vh; display:flex; flex-direction:column; border: 1px solid var(--border-line); }

  .servizi-list-modal { display: flex; flex-direction: column; gap: 8px; flex:1; overflow-y: auto; margin-bottom: 15px; }
  .serv-item { background: var(--bg-body); border: 1px solid var(--border-line); border-radius: 8px; padding: 12px; display: flex; align-items: center; gap: 10px; color: var(--text-main); }
  .serv-item.active { border-color: var(--accent); background: rgba(56,189,248,0.1); }
  
  .btn-add-service { width: 100%; padding: 15px; background: transparent; color: var(--text-main); border: 1px dashed var(--border-line); border-radius: 10px; font-size: 13px; font-weight: bold; display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 10px; cursor: pointer; }
  .selected-service-badge { background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3); border-radius: 10px; padding: 15px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }

  #toastBlue { visibility: hidden; min-width: 250px; background: var(--accent); color: #0f172a; text-align: center; border-radius: 12px; padding: 16px; position: fixed; z-index: 10001; left: 50%; transform: translateX(-50%); top: 20px; font-size: 14px; font-weight: bold; opacity: 0; transition: 0.4s; box-shadow: 0 10px 20px rgba(0,0,0,0.5);}
  #toastBlue.show { visibility: visible; opacity: 1; top: 40px; }
</style>
</head>
<body>

<div id="toastBlue"><i class="material-icons-round" style="vertical-align:middle; margin-right:5px">info</i> <span id="toastMsg">Notifica</span></div>

<script>
    if(!localStorage.getItem("tw_token")) window.location.href="login.html";
    if(localStorage.getItem('tw_theme') === 'light') document.documentElement.classList.add('light-theme');
</script>

<div class="app-header">
    <div class="header-title" id="mainHeaderTitle">Agenda Cabine</div>
    <div class="date-ctrl" id="headerDateCtrl">
        <button class="btn-arrow" onclick="m_changeDate(-1)"><i class="material-icons-round">chevron_left</i></button>
        <input type="date" id="mainDate" onchange="m_renderAll()">
        <button class="btn-arrow" onclick="m_changeDate(1)"><i class="material-icons-round">chevron_right</i></button>
    </div>
</div>

<div class="view-container">

    <div id="view-agenda" class="app-view active">
        <div class="grid-container" id="agendaGrid"></div>
        <button class="mobile-fab" onclick="m_openForm('', 1)"><i class="material-icons-round">add</i></button>
    </div>

    <div id="view-lista" class="app-view">
        <div style="padding:15px; background:var(--bg-panel); border-bottom:1px solid var(--border-line);">
            <input type="text" id="searchList" class="form-input" placeholder="🔍 Cerca ospite o camera..." onkeyup="m_renderLista()">
        </div>
        <div class="list-container" id="listaContainer">
            <div style="text-align:center; padding:40px; color:var(--text-muted);">Caricamento...</div>
        </div>
    </div>

    <div id="view-piscina" class="app-view" style="padding:0;">
        <iframe src="Piscina/Piscina_GUI.html" class="iframe-container" id="iframePiscina"></iframe>
    </div>

    <div id="view-chat" class="app-view">
        <div style="display:flex; padding:10px; gap:10px; background:var(--bg-panel); border-bottom:1px solid var(--border-line);">
            <button class="action-btn" id="btnChatDir" onclick="m_switchChat('public')" style="border-color:var(--accent); color:var(--accent);">Direzione</button>
            <button class="action-btn" id="btnChatRec" onclick="m_switchChat('reception')">Reception</button>
        </div>
        <div id="chatMessages" style="flex:1; overflow-y:auto; padding:15px; display:flex; flex-direction:column; gap:10px;"></div>
        <div style="display:flex; padding:10px; background:var(--bg-panel); border-top:1px solid var(--border-line);">
            <input type="text" id="chatMobileInput" class="form-input" style="margin-bottom:0; border-radius:20px 0 0 20px; outline:none;" placeholder="Scrivi un messaggio..." onkeypress="if(event.key==='Enter') m_sendChatMessage()">
            <button class="btn-save" style="width:auto; border-radius:0 20px 20px 0; padding:0 20px; margin:0;" onclick="m_sendChatMessage()"><i class="material-icons-round">send</i></button>
        </div>
    </div>

    <div id="view-menu" class="app-view padding-view">
        <div class="card-box">
            <h2><i class="material-icons-round">account_circle</i> Il Tuo Profilo</h2>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                <div><label style="font-size:10px; color:var(--text-muted);">Nome</label><div class="info-text" id="prof_name">-</div></div>
                <div><label style="font-size:10px; color:var(--text-muted);">Username</label><div class="info-text" id="prof_nick" style="color:var(--gold);">-</div></div>
            </div>
            
            <h2 style="margin-top:20px;"><i class="material-icons-round">euro</i> Resoconto Netto</h2>
            <input type="month" id="commMonth" class="form-input" style="margin-bottom:15px;" onchange="m_calcCommissions()">
            
            <div class="stats-grid">
                <div class="stat-card"><div class="stat-lbl">Fisso</div><div class="stat-val" id="valFisso">0 €</div></div>
                <div class="stat-card" style="border-bottom-color:var(--accent)"><div class="stat-lbl">Massaggi</div><div class="stat-val" id="valMassaggi" style="color:var(--accent);">0 €</div></div>
                <div class="stat-card" style="border-bottom-color:#db2777; grid-column: 1 / -1;"><div class="stat-lbl">Percorsi SPA</div><div class="stat-val" id="valSpa" style="color:#db2777;">0 €</div></div>
            </div>
            
            <div style="background:rgba(16, 185, 129, 0.1); border:1px solid rgba(16, 185, 129, 0.3); border-radius:12px; padding:20px; text-align:center;">
                <div style="font-size:12px; color:var(--green); font-weight:bold; text-transform:uppercase;">Totale Spettante</div>
                <div id="valTotale" style="font-size:36px; font-weight:900; color:var(--text-main);">0.00 €</div>
            </div>
        </div>

        <div class="card-box">
            <h2><i class="material-icons-round">settings</i> Impostazioni App</h2>
            <div style="display:flex; gap:10px; margin-bottom:15px;">
                <div class="theme-card" onclick="m_setTheme('dark')"><i class="material-icons-round" style="display:block; margin-bottom:5px;">dark_mode</i> Notte</div>
                <div class="theme-card" onclick="m_setTheme('light')" style="border-color:var(--border-line);"><i class="material-icons-round" style="display:block; margin-bottom:5px; color:#f59e0b">light_mode</i> Giorno</div>
            </div>
            
            <div class="switch-container" style="margin-top:0; margin-bottom:20px;">
                <div>
                    <div class="switch-lbl" style="font-weight:bold; font-size:12px;">Tasto WhatsApp</div>
                    <div style="font-size:10px; color:var(--text-muted);">Mostra in agenda.</div>
                </div>
                <label class="switch"><input type="checkbox" id="waToggle" onchange="m_toggleWA()"><span class="slider"></span></label>
            </div>

            <button class="btn-save" style="background:rgba(239, 68, 68, 0.1); border:1px solid rgba(239, 68, 68, 0.3); color:var(--red);" onclick="m_logout()">
                <i class="material-icons-round">logout</i> DISCONNETTI
            </button>
        </div>

    </div>
</div>

<div class="mobile-bottom-bar">
    <div id="nav-agenda" class="active" onclick="m_switchView('agenda')"><i class="material-icons-round">calendar_today</i><span>Agenda</span></div>
    <div id="nav-lista" onclick="m_switchView('lista')"><i class="material-icons-round">list_alt</i><span>Lista</span></div>
    <div id="nav-piscina" onclick="m_switchView('piscina')"><i class="material-icons-round">pool</i><span>Piscina</span></div>
    <div id="nav-chat" onclick="m_switchView('chat')"><i class="material-icons-round">forum</i><span>Chat</span></div>
    <div id="nav-menu" onclick="m_switchView('menu')"><i class="material-icons-round">menu</i><span>Menu</span></div>
</div>

<div class="bottom-sheet" id="appFormSheet">
    <div class="drag-handle" onclick="m_closeForm()"></div>
    <h3 style="color:var(--gold); margin:0 0 20px 0; font-size:18px; text-align:center;" id="formTitle">Nuovo Appuntamento</h3>
    
    <input type="hidden" id="fId"><input type="hidden" id="fOldDate"><input type="hidden" id="fCab">
    <input type="hidden" id="fReqId"><input type="hidden" id="fReqOldOra">
    
    <div style="display:flex; gap:10px">
        <div class="form-group"><label>Data</label><input type="date" id="fDate" class="form-input"></div>
        <div class="form-group"><label>Orario</label><input type="time" id="fOra" class="form-input"></div>
    </div>
    
    <div style="display:flex; gap:10px">
        <div class="form-group" style="flex:1"><label>Camera</label><input type="number" id="fCam" class="form-input" placeholder="N°"></div>
        <div class="form-group" style="flex:1.5"><label>Telefono</label><input type="tel" id="fTel" class="form-input" placeholder="Opzionale"></div>
    </div>
    
    <div class="form-group"><label>Ospite</label><input type="text" id="fCog" class="form-input" placeholder="Nome Ospite..."></div>
    <div class="form-group"><label>Operatore</label><select id="fOp" class="form-input"></select></div>

    <input type="hidden" id="fServ"><input type="hidden" id="fDur" value="30"><input type="hidden" id="fPrice" value="0">
    <div id="fServiceArea"></div>

    <div class="form-group" style="margin-top:10px"><label>Note</label><textarea id="fNote" class="form-input" rows="2"></textarea></div>
    
    <div class="switch-container" id="eseguitoSwitchBox">
        <label class="switch-lbl" style="font-weight:bold; font-size:12px;">TRATTAMENTO ESEGUITO</label>
        <label class="switch"><input type="checkbox" id="fEseguito"><span class="slider"></span></label>
    </div>
    
    <div style="display:flex; flex-direction:column; gap:10px; margin-top:20px; padding-bottom:30px;">
        <button id="btnSaveAppStandard" class="btn-save" onclick="m_saveApp()"><i class="material-icons-round">save</i> SALVA IN AGENDA</button>
        <div id="editActionButtons" style="display:none; flex-direction:column; gap:10px;">
            <button class="btn-save btn-wa" onclick="m_shareWA()"><i class="material-icons-round">whatsapp</i> INVIA WHATSAPP</button>
            <button class="btn-save btn-del" onclick="m_delApp()"><i class="material-icons-round">delete</i> ELIMINA APPUNTAMENTO</button>
        </div>
        <div id="reqActionButtons" style="display:none; flex-direction:column; gap:10px;">
            <button class="btn-save" style="background:var(--green); color:white;" onclick="m_acceptRequest()"><i class="material-icons-round">check_circle</i> ACCETTA E INSERISCI</button>
            <button class="btn-save btn-del" onclick="m_rejectRequest()"><i class="material-icons-round">cancel</i> RIFIUTA RICHIESTA</button>
        </div>
    </div>
</div>
<div class="mobile-backdrop" onclick="m_closeForm()"></div>

<div id="srvModal" class="modal-overlay" onclick="if(event.target===this) this.style.display='none'">
    <div class="modal-box">
        <h3 style="margin-top:0; border-bottom:1px solid var(--border-line); padding-bottom:10px;">Seleziona Servizio</h3>
        <div id="srvListUI" style="display:flex; flex-direction:column; gap:8px; overflow-y:auto; flex:1; margin-bottom:15px;"></div>
        <button class="btn-save btn-outline" onclick="document.getElementById('srvModal').style.display='none'">ANNULLA</button>
    </div>
</div>

<script>
    const fbConfig = {
        apiKey: "AIzaSyCrDuK7SWHdbzrJR-pNpxmRwGnZgV2Dd2Y",
        authDomain: "touch-welness-massage.firebaseapp.com",
        databaseURL: "https://touch-welness-massage-default-rtdb.europe-west1.firebasedatabase.app",
        projectId: "touch-welness-massage",
        storageBucket: "touch-welness-massage.firebasestorage.app"
    };

    if (!firebase.apps.length) firebase.initializeApp(fbConfig);

    const sId = localStorage.getItem("tw_structure_id");
    const uNick = localStorage.getItem("tw_user");
    let db = { app: {}, requests: {}, settings: {}, staff: [], servizi: [] };
    let uKey = null; let uData = null;
    let mRowHeight = 75; 

    function showToast(msg) { const t = document.getElementById("toastBlue"); document.getElementById("toastMsg").innerText = msg; t.classList.add("show"); setTimeout(() => t.classList.remove("show"), 3000); }

    const td = new Date();
    document.getElementById("mainDate").value = td.toISOString().split('T')[0];
    document.getElementById("commMonth").value = `${td.getFullYear()}-${String(td.getMonth()+1).padStart(2,'0')}`;

    firebase.database().ref('MASTER_ADMIN_DB/structures_data/' + sId).on('value', snap => {
        const val = snap.val() || {};
        db.app = val.app || {}; 
        db.requests = val.requests || {}; 
        db.settings = val.settings || {};
        db.staff = Array.isArray(val.staff) ? val.staff : Object.values(val.staff || {});
        db.servizi = Array.isArray(val.servizi) ? val.servizi : Object.values(val.servizi || {});
        m_renderAll(); 
    });

    firebase.database().ref('MASTER_ADMIN_DB/users').on('value', snap => {
        const users = snap.val() || {};
        for(let key in users) { if(users[key].nick === uNick) { uKey = key; uData = users[key]; break; } }
        m_renderProfilo(); m_calcCommissions();
    });

    let currentView = 'agenda';
    function m_switchView(viewName) {
        currentView = viewName;
        document.querySelectorAll('.app-view').forEach(e => e.classList.remove('active'));
        document.querySelectorAll('.mobile-bottom-bar div').forEach(e => e.classList.remove('active'));
        
        document.getElementById('view-' + viewName).classList.add('active');
        document.getElementById('nav-' + viewName).classList.add('active');

        const title = document.getElementById('mainHeaderTitle');
        const dCtrl = document.getElementById('headerDateCtrl');

        if(viewName === 'agenda') { title.innerText = "Agenda Cabine"; dCtrl.style.display = "flex"; }
        if(viewName === 'lista') { title.innerText = "Lista Completa"; dCtrl.style.display = "none"; }
        if(viewName === 'piscina') { title.innerText = "Piscina e SPA"; dCtrl.style.display = "none"; }
        if(viewName === 'chat') { title.innerText = "Chat Interna"; dCtrl.style.display = "none"; m_switchChat('public'); }
        if(viewName === 'menu') { title.innerText = "Menu App"; dCtrl.style.display = "none"; }

        m_renderAll();
    }

    function m_changeDate(offset) {
        const p = document.getElementById("mainDate");
        const d = new Date(p.value); d.setDate(d.getDate() + offset);
        p.value = d.toISOString().split('T')[0];
        m_renderAll();
    }

    function m_renderAll() {
        if(currentView === 'agenda') m_renderAgenda();
        if(currentView === 'lista') m_renderLista();
        if(currentView === 'menu') { document.getElementById('waToggle').checked = db.settings.waEnabled !== false; }
    }

    /* LOGICA CHAT NATIVA MOBILE */
    let m_currentChatRoom = 'public';
    function m_switchChat(room) {
        m_currentChatRoom = room;
        document.getElementById('btnChatDir').style.color = (room==='public')?'var(--accent)':'var(--text-muted)';
        document.getElementById('btnChatDir').style.borderColor = (room==='public')?'var(--accent)':'var(--border-line)';
        document.getElementById('btnChatRec').style.color = (room==='reception')?'var(--accent)':'var(--text-muted)';
        document.getElementById('btnChatRec').style.borderColor = (room==='reception')?'var(--accent)':'var(--border-line)';
        
        const chatBox = document.getElementById('chatMessages');
        chatBox.innerHTML = '<div style="text-align:center; color:var(--text-muted); font-size:12px; margin-top:20px;">Caricamento messaggi...</div>';
        
        firebase.database().ref(`MASTER_ADMIN_DB/structures_data/${sId}/chats/${m_currentChatRoom}`).on('value', snap => {
            chatBox.innerHTML = '';
            const msgs = snap.val() || {};
            const arr = Object.values(msgs).sort((a,b)=>a.timestamp - b.timestamp);
            if(arr.length === 0) { chatBox.innerHTML = '<div style="text-align:center; color:var(--text-muted); font-size:12px; margin-top:20px;">Nessun messaggio in questa stanza.</div>'; }
            arr.forEach(m => {
                const isMe = m.sender === uNick;
                const align = isMe ? 'flex-end' : 'flex-start';
                const bg = isMe ? 'var(--accent)' : 'var(--bg-panel)';
                const col = isMe ? '#0f172a' : 'var(--text-main)';
                chatBox.innerHTML += `<div style="align-self:${align}; max-width:80%; background:${bg}; color:${col}; padding:10px 15px; border-radius:15px; font-size:13px; box-shadow:0 2px 5px rgba(0,0,0,0.2);">
                    <div style="font-size:9px; opacity:0.7; margin-bottom:4px; font-weight:bold; text-transform:uppercase;">${m.sender} - ${m.date}</div>
                    ${m.text}
                </div>`;
            });
            setTimeout(() => chatBox.scrollTop = chatBox.scrollHeight, 100);
        });
    }

    function m_sendChatMessage() {
        const input = document.getElementById('chatMobileInput');
        const txt = input.value.trim();
        if(!txt) return;
        const msg = { sender: uNick || "Staff SPA", text: txt, timestamp: Date.now(), date: new Date().toLocaleString('it-IT') };
        firebase.database().ref(`MASTER_ADMIN_DB/structures_data/${sId}/chats/${m_currentChatRoom}`).push(msg).then(() => {
            input.value = '';
        });
    }

    /* AGENDA CABINE */
    function tToM(t) { const p = t.split(':'); return (parseInt(p[0])||0)*60 + (parseInt(p[1])||0); }
    function mToT(m) { return `${String(Math.floor(m/60)).padStart(2,'0')}:${String(m%60).padStart(2,'0')}`; }

    function m_renderAgenda() {
        const grid = document.getElementById("agendaGrid");
        const d = document.getElementById("mainDate").value; 
        const nCabine = (db.settings && db.settings.cabine) ? parseInt(db.settings.cabine) : 2;
        
        let dayApps = Array.isArray(db.app[d]) ? db.app[d] : Object.values(db.app[d] || {});
        let dayReqs = Array.isArray(db.requests[d]) ? db.requests[d] : Object.values(db.requests[d] || {});

        let h = "";
        for(let c = 1; c <= nCabine; c++) {
            h += `<div class="colonna"><div class="col-head">CABINA ${c}</div>`;
            for(let i=10*60; i<=20*60; i+=10) {
                const s = mToT(i); const sMin = i;
                
                const startApp = dayApps.find(x => x && x.ora === s && parseInt(x.cab) === c);
                const busyApp = dayApps.find(x => { if(!x || !x.ora) return false; const start = tToM(x.ora); return parseInt(x.cab) === c && sMin > start && sMin < start + (parseInt(x.dur) || 30); });
                
                const startReq = dayReqs.find(x => x && x.ora === s && parseInt(x.cab) === c && x.status === 'pending');
                const busyReq = dayReqs.find(x => { if(!x || !x.ora || x.status !== 'pending') return false; const start = tToM(x.ora); return parseInt(x.cab) === c && sMin > start && sMin < start + (parseInt(x.dur) || 30); });

                if(startApp) {
                    const isEseg = startApp.eseguito ? "eseguito-style" : "";
                    const slotsCount = Math.ceil((parseInt(startApp.dur) || 30) / 10);
                    const hCss = `height: calc(${slotsCount * 100}% + ${slotsCount - 1}px - 6px); top: 3px;`;
                    
                    h += `<div class="time-row"><div class="time-lbl">${s}</div>
                          <div class="slot" data-ora="${s}" data-cab="${c}">
                            <div class="app-base ${isEseg}" style="${hCss}" 
                                 ontouchstart="m_touchStart(event, '${startApp.id}')" ontouchmove="m_touchMove(event)" ontouchend="m_touchEnd(event)"
                                 onclick="m_openForm('${startApp.id}')">
                                <div class="app-info-col">
                                    <b>Cam ${startApp.cam || '?'} - ${startApp.cog || 'N.D.'}</b>
                                    <span style="font-size:10px; opacity:0.9;">${startApp.serv || '-'} (${startApp.dur||30}m)</span>
                                </div>
                            </div>
                          </div></div>`;
                } else if(busyApp) {
                    h += `<div class="time-row"><div class="time-lbl">${s}</div><div class="slot"><div class="app-busy" onclick="m_openForm('${busyApp.id}')"></div></div></div>`;
                } else if(startReq) {
                    const slotsCount = Math.ceil((parseInt(startReq.dur) || 30) / 10);
                    const hCss = `height: calc(${slotsCount * 100}% + ${slotsCount - 1}px - 6px); top: 3px;`;
                    
                    h += `<div class="time-row"><div class="time-lbl">${s}</div>
                          <div class="slot">
                            <div class="app-base req-style" style="${hCss}" onclick="m_openRequest('${startReq.id}')">
                                <div class="app-info-col">
                                    <b><i class="material-icons-round" style="font-size:12px">notifications_active</i> RICHIESTA SPA</b>
                                    <span style="font-size:10px; opacity:0.9;">Cam ${startReq.cam || '?'} - ${startReq.serv || '-'}</span>
                                </div>
                            </div>
                          </div></div>`;
                } else if(busyReq) {
                    h += `<div class="time-row"><div class="time-lbl">${s}</div><div class="slot"><div class="app-busy req-busy" onclick="m_openRequest('${busyReq.id}')"></div></div></div>`;
                } else {
                    h += `<div class="time-row"><div class="time-lbl">${s}</div><div class="slot" data-ora="${s}" data-cab="${c}" onclick="m_openForm('', ${c}, '${s}')"></div></div>`;
                }
            }
            h += `</div>`;
        }
        grid.innerHTML = h;
    }

    /* DRAG DROP TOUCH */
    let tTimer=null, isDrag=false, jDrag=false, dAppId=null, dEl=null, oX=0, oY=0;
    let lastDropTarget = null;

    function m_touchStart(e, appId) {
        if(e.touches.length !== 1) return;
        const touch = e.touches[0]; const target = e.currentTarget;
        tTimer = setTimeout(() => {
            isDrag = true; dAppId = appId; dEl = target.cloneNode(true);
            document.body.style.touchAction = 'none'; document.body.style.overflow = 'hidden';
            dEl.style.position = 'fixed'; dEl.style.zIndex = '9999'; dEl.style.opacity = '0.9'; 
            dEl.style.width = target.offsetWidth + 'px'; dEl.style.height = target.offsetHeight + 'px'; 
            dEl.style.pointerEvents = 'none'; dEl.style.boxShadow = '0 10px 25px rgba(0,0,0,0.6)'; dEl.style.border = '2px solid var(--accent)';
            document.body.appendChild(dEl);
            const rect = target.getBoundingClientRect(); oX = touch.clientX - rect.left; oY = touch.clientY - rect.top;
            dEl.style.left = (touch.clientX - oX) + 'px'; dEl.style.top = (touch.clientY - oY) + 'px';
            if(navigator.vibrate) navigator.vibrate(50);
            target.classList.add('dragging');
        }, 400);
    }

    function m_touchMove(e) { 
        if(!isDrag) { clearTimeout(tTimer); return; } 
        e.preventDefault(); 
        const touch = e.touches[0]; 
        if(dEl) { 
            dEl.style.left = (touch.clientX - oX) + 'px'; dEl.style.top = (touch.clientY - oY) + 'px'; 
            const dropTarget = document.elementFromPoint(touch.clientX, touch.clientY);
            const slot = dropTarget ? dropTarget.closest('.slot') : null;
            if(lastDropTarget && lastDropTarget !== slot) { lastDropTarget.classList.remove('drag-over'); }
            if(slot && !slot.querySelector('.app-busy') && slot.hasAttribute('data-ora')) { slot.classList.add('drag-over'); lastDropTarget = slot; }
        } 
    }

    function m_touchEnd(e) {
        clearTimeout(tTimer); e.currentTarget.classList.remove('dragging');
        document.body.style.touchAction = ''; document.body.style.overflow = '';
        if(lastDropTarget) { lastDropTarget.classList.remove('drag-over'); lastDropTarget = null; }
        if(!isDrag) return; 
        isDrag = false; jDrag = true; setTimeout(() => jDrag = false, 200);
        if(dEl) {
            const touch = e.changedTouches[0]; dEl.style.display = 'none';
            const dropTarget = document.elementFromPoint(touch.clientX, touch.clientY); dEl.remove(); dEl = null;
            if(dropTarget) {
                const slot = dropTarget.closest('.slot');
                if(slot && slot.hasAttribute('data-ora') && !slot.querySelector('.app-busy')) { m_moveApp(dAppId, slot.getAttribute('data-ora'), slot.getAttribute('data-cab')); }
            }
        }
        dAppId = null;
    }

    function m_moveApp(appId, newOra, newCab) {
        const d = document.getElementById("mainDate").value; 
        let apps = Array.isArray(db.app[d]) ? db.app[d] : Object.values(db.app[d] || {});
        const idx = apps.findIndex(x => x && x.id === appId);
        if(idx > -1) {
            const startMin = tToM(newOra); const appDur = parseInt(apps[idx].dur) || 30; const endMin = startMin + appDur;
            let collision = apps.some(a => { if(!a || a.id === appId || parseInt(a.cab) !== parseInt(newCab)) return false; const aStart = tToM(a.ora); return (startMin < aStart + (parseInt(a.dur)||30) && endMin > aStart); });
            if(collision) return showToast("Orario Occupato!");
            apps[idx].ora = newOra; apps[idx].cab = newCab;
            firebase.database().ref('MASTER_ADMIN_DB/structures_data/' + sId + '/app/' + d).set(apps).then(() => showToast("Spostato!"));
        }
    }

    /* PINCH TO ZOOM */
    let initialPinchDistance = null; let initialRowHeight = mRowHeight;
    function getPinchDistance(touches) { return Math.hypot(touches[0].clientX - touches[1].clientX, touches[0].clientY - touches[1].clientY); }
    document.getElementById('view-agenda').addEventListener('touchstart', function(e) { if (e.touches.length === 2) { initialPinchDistance = getPinchDistance(e.touches); initialRowHeight = mRowHeight; } }, {passive: false});
    document.getElementById('view-agenda').addEventListener('touchmove', function(e) {
        if (e.touches.length === 2 && initialPinchDistance) {
            e.preventDefault(); const currentDistance = getPinchDistance(e.touches); const scale = currentDistance / initialPinchDistance;
            let newHeight = initialRowHeight * scale; if (newHeight < 35) newHeight = 35; if (newHeight > 150) newHeight = 150; 
            mRowHeight = newHeight; document.documentElement.style.setProperty('--row-height', mRowHeight + 'px');
        }
    }, {passive: false});
    document.getElementById('view-agenda').addEventListener('touchend', function(e) { if (e.touches.length < 2) { initialPinchDistance = null; } });

    /* VISTA LISTA */
    function m_renderLista() {
        const container = document.getElementById("listaContainer"); const query = document.getElementById("searchList").value.toLowerCase();
        let all = []; Object.keys(db.app).forEach(d => { let dayApps = Array.isArray(db.app[d]) ? db.app[d] : Object.values(db.app[d]); dayApps.forEach(a => { if(a && a.id) all.push({...a, fullDate: d}); }); });
        all.sort((a,b) => (b.fullDate+" "+b.ora).localeCompare(a.fullDate+" "+a.ora));
        let filtered = all.filter(a => (a.cog||'').toLowerCase().includes(query) || (a.cam||'').includes(query));
        if(filtered.length === 0) { container.innerHTML = "<div style='text-align:center; padding:30px; color:var(--text-muted)'>Nessun appuntamento.</div>"; return; }
        container.innerHTML = filtered.map(a => {
            const isEseg = a.eseguito ? "done" : ""; const isPaid = a.pagato ? "paid" : ""; const dFormat = a.fullDate.split('-').reverse().join('/');
            return `<div class="app-card"><div><div class="app-id" onclick="m_openForm('${a.id}')">#${a.id} (Modifica)</div><div style="font-size:16px; font-weight:900; color:var(--text-main); text-transform:uppercase; margin-top:5px;">${a.cog || 'N.D.'}</div><div style="font-size:12px; color:var(--text-muted); margin-top:5px;"><i class="material-icons-round" style="font-size:12px; vertical-align:middle; color:var(--accent);">calendar_today</i> ${dFormat} | ${a.ora} | Cam: ${a.cam}</div></div><div class="app-actions"><div class="action-btn ${isEseg}" onclick="m_toggleState('${a.id}', '${a.fullDate}', 'eseguito')"><i class="material-icons-round">${a.eseguito?'check_circle':'radio_button_unchecked'}</i> ${a.eseguito?'ESEGUITO':'ESEGUITO?'}</div><div class="action-btn ${isPaid}" onclick="m_toggleState('${a.id}', '${a.fullDate}', 'pagato')"><i class="material-icons-round">${a.pagato?'monetization_on':'account_balance_wallet'}</i> ${a.pagato?'PAGATO':'PAGATO?'}</div><div class="action-btn del" onclick="m_delAppFromList('${a.id}', '${a.fullDate}')"><i class="material-icons-round">delete</i></div></div></div>`;
        }).join('');
    }

    function m_toggleState(id, date, field) { let apps = Array.isArray(db.app[date]) ? db.app[date] : Object.values(db.app[date]); const idx = apps.findIndex(x => x && x.id === id); if(idx > -1) { apps[idx][field] = !apps[idx][field]; firebase.database().ref('MASTER_ADMIN_DB/structures_data/' + sId + '/app/' + date).set(apps); } }
    function m_delAppFromList(id, d) { const m = prompt("Motivazione dell'annullamento:"); if(m === null) return; let apps = Array.isArray(db.app[d]) ? db.app[d] : Object.values(db.app[d]); const appToDel = apps.find(x => x.id === id); apps = apps.filter(x => x.id !== id); firebase.database().ref('MASTER_ADMIN_DB/structures_data/' + sId + '/app/' + d).set(apps).then(() => { if(appToDel) { appToDel.deleteReason = m || "Nessuna motivazione"; appToDel.date = d; appToDel.deletedAt = new Date().toLocaleString('it-IT'); firebase.database().ref('MASTER_ADMIN_DB/structures_data/' + sId + '/deleted_apps').push(appToDel); } showToast("Eliminato!"); m_renderLista(); }); }

    /* MENU PROFILO */
    function m_renderProfilo() { if(!uData) return; document.getElementById("prof_name").innerText = `${uData.name || ''} ${uData.surname || ''}`; document.getElementById("prof_nick").innerText = uData.nick || ''; }
    function m_calcCommissions() { if(!uData) return; const period = document.getElementById("commMonth").value; const comm = uData.commissions || {}; const fisso = parseFloat(comm.fisso) || 0; const ivaPerc = parseFloat(comm.iva) || 0; const pMas = parseFloat(comm.op_massaggi) || 0; const pSpa = parseFloat(comm.op_spa) || 0; let tMas = 0, tSpa = 0; Object.keys(db.app).forEach(dateStr => { if(dateStr.startsWith(period)) { let dayApps = Array.isArray(db.app[dateStr]) ? db.app[dateStr] : Object.values(db.app[dateStr]); dayApps.forEach(a => { if(a && a.eseguito && a.pagato && (a.op === uData.nick || a.op === uData.name)) { let lordo = parseFloat(a.price) || parseFloat(a.prezzo) || 0; let netto = lordo / (1 + (ivaPerc / 100)); let sName = (a.serv || "").toLowerCase(); if(sName.includes('spa') || sName.includes('percors')) tSpa += netto * (pSpa/100); else tMas += netto * (pMas/100); } }); } }); document.getElementById('valFisso').innerText = fisso.toFixed(2) + " €"; document.getElementById('valMassaggi').innerText = tMas.toFixed(2) + " €"; document.getElementById('valSpa').innerText = tSpa.toFixed(2) + " €"; document.getElementById('valTotale').innerText = (fisso + tMas + tSpa).toFixed(2) + " €"; }
    function m_toggleWA() { firebase.database().ref('MASTER_ADMIN_DB/structures_data/' + sId + '/settings').update({waEnabled: document.getElementById('waToggle').checked}); }
    function m_setTheme(t) { localStorage.setItem('tw_theme', t); if(t==='light') document.documentElement.classList.add('light-theme'); else document.documentElement.classList.remove('light-theme'); showToast("Tema Aggiornato"); }
    function m_logout() { localStorage.clear(); window.location.href="login.html"; }

    /* FORM BOTTOM SHEET */
    function m_openForm(id = '', cab = 1, ora = "10:00") {
        if(jDrag) return; const sel = document.getElementById("fOp"); sel.innerHTML = '<option value="">-- Operatore --</option>'; db.staff.forEach(s => { if(s.nome) sel.innerHTML += `<option value="${s.nome}">${s.nome}</option>`; });
        if(id) {
            let targetApp = null; let tDate = null; Object.keys(db.app).forEach(d => { let arr = Array.isArray(db.app[d]) ? db.app[d] : Object.values(db.app[d]); let found = arr.find(x => x && x.id === id); if(found) { targetApp = found; tDate = d; } });
            if(!targetApp) return;
            document.getElementById("formTitle").innerText = "Modifica Appuntamento"; document.getElementById("formTitle").style.color = "var(--gold)"; document.getElementById("fId").value = id; document.getElementById("fDate").value = tDate; document.getElementById("fOldDate").value = tDate; document.getElementById("fReqId").value = ""; document.getElementById("fOra").value = targetApp.ora; document.getElementById("fCab").value = targetApp.cab; document.getElementById("fCam").value = targetApp.cam; document.getElementById("fTel").value = targetApp.tel || ""; document.getElementById("fCog").value = targetApp.cog || ""; document.getElementById("fOp").value = targetApp.op || ""; document.getElementById("fNote").value = targetApp.note || ""; document.getElementById("fEseguito").checked = targetApp.eseguito || false; document.getElementById("fServ").value = targetApp.serv || ""; document.getElementById("fDur").value = targetApp.dur || 30; document.getElementById("fPrice").value = targetApp.price || 0;
            document.getElementById("eseguitoSwitchBox").style.display = "flex"; document.getElementById("btnSaveAppStandard").style.display = "flex"; document.getElementById("editActionButtons").style.display = "flex"; document.getElementById("reqActionButtons").style.display = "none";
        } else {
            document.getElementById("formTitle").innerText = "Nuovo Appuntamento"; document.getElementById("formTitle").style.color = "var(--gold)"; document.getElementById("fId").value = ""; document.getElementById("fReqId").value = ""; let cd = document.getElementById("mainDate").value || new Date().toISOString().split('T')[0]; document.getElementById("fDate").value = cd; document.getElementById("fOldDate").value = cd; document.getElementById("fOra").value = ora; document.getElementById("fCab").value = cab; ['fCam','fTel','fCog','fOp','fNote','fServ'].forEach(x => document.getElementById(x).value=""); document.getElementById("fDur").value = "30"; document.getElementById("fPrice").value = "0"; document.getElementById("fEseguito").checked = false; 
            document.getElementById("eseguitoSwitchBox").style.display = "flex"; document.getElementById("btnSaveAppStandard").style.display = "flex"; document.getElementById("editActionButtons").style.display = "none"; document.getElementById("reqActionButtons").style.display = "none";
        }
        m_renderServiceBox(); document.getElementById("appFormSheet").classList.add("active");
    }

    function m_openRequest(reqId) {
        if(jDrag) return; const d = document.getElementById("mainDate").value; let reqs = Array.isArray(db.requests[d]) ? db.requests[d] : Object.values(db.requests[d] || {}); const req = reqs.find(x => x && x.id === reqId); if(!req) return;
        const sel = document.getElementById("fOp"); sel.innerHTML = '<option value="">-- Operatore --</option>'; db.staff.forEach(s => { if(s.nome) sel.innerHTML += `<option value="${s.nome}">${s.nome}</option>`; });
        document.getElementById("formTitle").innerText = "GESTISCI RICHIESTA"; document.getElementById("formTitle").style.color = "var(--purple)"; document.getElementById("fId").value = ""; document.getElementById("fReqId").value = req.id; document.getElementById("fReqOldOra").value = req.ora; document.getElementById("fDate").value = d; document.getElementById("fOldDate").value = d; document.getElementById("fOra").value = req.ora; document.getElementById("fCab").value = req.cab; document.getElementById("fCam").value = req.cam || ""; document.getElementById("fTel").value = req.tel || ""; document.getElementById("fCog").value = req.cog || ""; document.getElementById("fOp").value = ""; document.getElementById("fNote").value = req.note || ""; document.getElementById("fEseguito").checked = false; document.getElementById("fServ").value = req.serv || ""; document.getElementById("fDur").value = req.dur || 30; document.getElementById("fPrice").value = req.price || 0;
        document.getElementById("eseguitoSwitchBox").style.display = "none"; document.getElementById("btnSaveAppStandard").style.display = "none"; document.getElementById("editActionButtons").style.display = "none"; document.getElementById("reqActionButtons").style.display = "flex";
        m_renderServiceBox(); document.getElementById("appFormSheet").classList.add("active");
    }

    function m_closeForm() { document.getElementById("appFormSheet").classList.remove("active"); }

    function m_renderServiceBox() { const area = document.getElementById("fServiceArea"); const n = document.getElementById("fServ").value; if(n) area.innerHTML = `<div class="selected-service-badge"><div class="info"><b style="color:var(--green)">${n}</b><span>${document.getElementById('fDur').value} min | ${document.getElementById('fPrice').value} €</span></div><div class="icon-del" onclick="document.getElementById('fServ').value=''; m_renderServiceBox()"><i class="material-icons-round" style="font-size:16px;">close</i></div></div>`; else area.innerHTML = `<button class="btn-add-service" onclick="m_openSrvModal()"><i class="material-icons-round" style="color:var(--accent);">add_circle</i> SCEGLI SERVIZIO</button>`; }
    function m_openSrvModal() { const l = document.getElementById("srvListUI"); l.innerHTML = ""; db.servizi.forEach(s => { if(s.nome) l.innerHTML += `<div class="serv-item" onclick="m_selectSrv('${s.nome.replace(/'/g,"\\'")}', ${s.durata||30}, ${s.prezzo||0})"><b>${s.nome}</b> <span style="margin-left:auto; color:var(--accent); font-size:11px;">${s.durata}m - ${s.prezzo}€</span></div>`; }); document.getElementById("srvModal").style.display = "flex"; }
    function m_selectSrv(n, d, p) { document.getElementById("fServ").value = n; document.getElementById("fDur").value = d; document.getElementById("fPrice").value = p; m_renderServiceBox(); document.getElementById("srvModal").style.display = "none"; }

    function m_saveApp() {
        const id = document.getElementById("fId").value; const date = document.getElementById("fDate").value; const oldDate = document.getElementById("fOldDate").value;
        if(!date || !document.getElementById("fCam").value || !document.getElementById("fServ").value) return showToast("Mancano dati obbligatori");
        const obj = { id: id || "APP"+Date.now(), ora: document.getElementById("fOra").value, cab: document.getElementById("fCab").value, cam: document.getElementById("fCam").value, tel: document.getElementById("fTel").value, cog: document.getElementById("fCog").value, op: document.getElementById("fOp").value, serv: document.getElementById("fServ").value, dur: parseInt(document.getElementById("fDur").value), price: parseFloat(document.getElementById("fPrice").value), note: document.getElementById("fNote").value, eseguito: document.getElementById("fEseguito").checked, pagato: false };
        const dbRefLocal = firebase.database().ref('MASTER_ADMIN_DB/structures_data/' + sId + '/app');
        if(id && oldDate && oldDate !== date) { let oldApps = Array.isArray(db.app[oldDate]) ? db.app[oldDate] : Object.values(db.app[oldDate]); dbRefLocal.child(oldDate).set(oldApps.filter(x => x.id !== id)); }
        let apps = Array.isArray(db.app[date]) ? db.app[date] : Object.values(db.app[date] || {});
        if(id && oldDate === date) { const i = apps.findIndex(x => x.id === id); if(i > -1) { obj.pagato = apps[i].pagato; obj.fromReception = apps[i].fromReception; obj.reqId = apps[i].reqId; apps[i] = obj; } else apps.push(obj); } else { apps.push(obj); }
        dbRefLocal.child(date).set(apps).then(() => { m_closeForm(); showToast("Salvato!"); m_renderLista(); });
    }

    function m_acceptRequest() {
        const reqId = document.getElementById('fReqId').value; const d = document.getElementById("fDate").value; const confOra = document.getElementById('fOra').value; const oldOra = document.getElementById('fReqOldOra').value; const sName = document.getElementById('fServ').value;
        if(!document.getElementById("fCam").value || !sName) return showToast("Mancano dati obbligatori!");
        let reqs = Array.isArray(db.requests[d]) ? db.requests[d] : Object.values(db.requests[d] || {}); const req = reqs.find(x => x && x.id === reqId); if(!req) return;
        const newApp = { id: "APP" + Date.now(), reqId: reqId, ora: confOra, cab: document.getElementById("fCab").value, cam: document.getElementById("fCam").value, cog: document.getElementById("fCog").value.trim(), tel: document.getElementById("fTel").value.trim(), serv: sName, dur: parseInt(document.getElementById("fDur").value) || 30, price: parseFloat(document.getElementById("fPrice").value) || 0, op: document.getElementById("fOp").value, note: document.getElementById("fNote").value, eseguito: false, pagato: false, fromReception: true };
        const dbRefLocal = firebase.database().ref('MASTER_ADMIN_DB/structures_data/' + sId); let apps = Array.isArray(db.app[d]) ? db.app[d] : Object.values(db.app[d] || {}); apps.push(newApp); req.status = 'accepted';
        const isChanged = confOra !== oldOra; const logMsg = isChanged ? `L'appuntamento è stato inserito in agenda modificando l'orario (Da ${oldOra} a ${confOra}).` : `L'appuntamento è stato confermato regolarmente.`;
        Promise.all([ dbRefLocal.child('app').child(d).set(apps), dbRefLocal.child('requests').child(d).set(reqs), dbRefLocal.child('requests_log').child(reqId).update({ type: isChanged ? 'modified-accepted' : 'accepted', ora: confOra, msg: logMsg, date: new Date().toLocaleString('it-IT'), timestamp: Date.now() }) ]).then(() => { m_closeForm(); showToast("Confermato e Inserito!"); });
    }

    function m_rejectRequest() {
        const motivo = prompt("Motivazione del rifiuto (Obbligatoria):"); if(!motivo) { showToast("Devi inserire un motivo per rifiutare."); return; }
        const reqId = document.getElementById("fReqId").value; const d = document.getElementById("fDate").value; let reqs = Array.isArray(db.requests[d]) ? db.requests[d] : Object.values(db.requests[d] || {}); const req = reqs.find(x => x && x.id === reqId); if(!req) return; req.status = 'rejected';
        const dbRefLocal = firebase.database().ref('MASTER_ADMIN_DB/structures_data/' + sId);
        Promise.all([ dbRefLocal.child('requests').child(d).set(reqs), dbRefLocal.child('requests_log').child(reqId).update({ type: 'rejected', msg: `Richiesta RIFIUTATA. Motivo: ${motivo}`, date: new Date().toLocaleString('it-IT'), timestamp: Date.now() }) ]).then(() => { m_closeForm(); showToast("Richiesta Rifiutata."); });
    }

    function m_delApp() {
        const d = document.getElementById("fOldDate").value; const id = document.getElementById("fId").value; let apps = Array.isArray(db.app[d]) ? db.app[d] : Object.values(db.app[d] || {}); const appToDel = apps.find(x => x && x.id === id); 
        if (appToDel && appToDel.fromReception) { const motivo = prompt("App. inviato dalla Reception. Inserisci motivo eliminazione:"); if(!motivo) { showToast("Motivo obbligatorio."); return; } m_executeDeleteApp(motivo, appToDel, apps, d, id); } 
        else { if(confirm("Sei sicuro di voler eliminare?")) { m_executeDeleteApp("Cancellato dallo Staff", appToDel, apps, d, id); } }
    }

    function m_executeDeleteApp(motivo, appToDel, apps, d, id) {
        apps = apps.filter(x => x && x.id !== id); const dbRefLocal = firebase.database().ref('MASTER_ADMIN_DB/structures_data/' + sId); let promises = [dbRefLocal.child('app').child(d).set(apps)];
        if(appToDel) { appToDel.deleteReason = motivo; appToDel.date = d; appToDel.deletedAt = new Date().toLocaleString('it-IT'); appToDel.deletedBy = uNick || "Staff"; promises.push(dbRefLocal.child('deleted_apps').push(appToDel)); if(appToDel.fromReception && appToDel.reqId) { promises.push(dbRefLocal.child('requests_log').child(appToDel.reqId).update({ type: 'deleted-after', msg: `CANCELLATO dalla SPA. Motivo: ${motivo}`, date: new Date().toLocaleString('it-IT'), timestamp: Date.now() })); } } 
        Promise.all(promises).then(() => { m_closeForm(); showToast("Eliminato."); m_renderLista(); });
    }

    function m_shareWA() { const t = document.getElementById("fTel").value; if(t) window.open(`https://wa.me/${t}?text=Gentile%20Ospite,%20ti%20aspettiamo%20in%20SPA.`, '_blank'); }
</script>

<div id="sigModal" class="modal-overlay" style="display:none; align-items:flex-end; padding:0; background:rgba(0,0,0,0.7); z-index:9999;">
    <div class="modal-box" style="width:100%; max-width:100%; border-radius:24px 24px 0 0; margin:0; padding:25px; animation: slideUp 0.3s ease; background:var(--bg-panel);">
        <h3 style="margin-top:0; color:var(--accent); text-align:center;">Firma Modulo Privacy</h3>
        <p style="font-size:12px; color:var(--text-muted); text-align:center; margin-bottom:15px;" id="sigClientName">Apponi la tua firma all'interno del riquadro sottostante.</p>
        <canvas id="sigCanvas" style="border:2px dashed var(--border-line); border-radius:12px; width:100%; height:250px; background:#fff; touch-action:none;"></canvas>
        <div style="display:flex; gap:10px; margin-top:20px;">
            <button class="btn-save btn-outline" style="width:100%" onclick="closeSignatureModal()">ANNULLA</button>
            <button class="btn-save btn-outline" style="width:100%" onclick="clearCanvas()"><i class="material-icons-round">refresh</i> PULISCI</button>
            <button class="btn-save" style="background:var(--green); color:white; width:100%" id="btnSendSig" onclick="uploadSignature()"><i class="material-icons-round">cloud_upload</i> SALVA PDF</button>
        </div>
    </div>
</div>
<style>@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }</style>

<script>
const MAKE_WEBHOOK_URL = 'https://hook.eu1.make.com/mlpkbaerv5kjtmj9gol8u6fkas17aejk';

window.DeviceSyncMobile = {
    init: function() {
        const sid = localStorage.getItem('tw_structure_id');
        if(!sid) return;
        firebase.database().ref(`MASTER_ADMIN_DB/structures_data/${sid}/device_sync`).on('value', snap => {
            const syncs = snap.val() || {};
            Object.entries(syncs).forEach(([user, data]) => {
                if(data.status === 'pending') {
                    if(typeof openSignatureModal === 'function') openSignatureModal(user, data.appId, data.date, sid);
                }
            });
        });
    }
};
document.addEventListener('DOMContentLoaded', () => { window.DeviceSyncMobile.init(); });

let sigCanvas, sigCtx, drawingSig = false;
function initCanvas() {
    sigCanvas = document.getElementById('sigCanvas');
    sigCtx = sigCanvas.getContext('2d');
    sigCanvas.width = sigCanvas.offsetWidth; 
    sigCanvas.height = sigCanvas.offsetHeight;
    sigCtx.lineWidth = 3; sigCtx.lineCap = 'round'; sigCtx.strokeStyle = '#0f172a';
    
    const getPos = (e) => {
        const rect = sigCanvas.getBoundingClientRect();
        const evt = e.touches ? e.touches[0] : e;
        return { x: evt.clientX - rect.left, y: evt.clientY - rect.top };
    };
    
    const startDraw = (e) => { drawingSig = true; const p = getPos(e); sigCtx.beginPath(); sigCtx.moveTo(p.x, p.y); e.preventDefault(); };
    const draw = (e) => { if(!drawingSig) return; const p = getPos(e); sigCtx.lineTo(p.x, p.y); sigCtx.stroke(); e.preventDefault(); };
    const stopDraw = () => { drawingSig = false; sigCtx.closePath(); };
    
    sigCanvas.addEventListener('mousedown', startDraw); sigCanvas.addEventListener('mousemove', draw); sigCanvas.addEventListener('mouseup', stopDraw); sigCanvas.addEventListener('mouseout', stopDraw);
    sigCanvas.addEventListener('touchstart', startDraw, {passive: false}); sigCanvas.addEventListener('touchmove', draw, {passive: false}); sigCanvas.addEventListener('touchend', stopDraw);
}

window.openSignatureModal = function(user, appId, date, sid) {
    window.currentSyncUser = user; window.currentSyncAppId = appId; window.currentSyncDate = date; window.currentSyncSid = sid;
    document.getElementById('sigModal').style.display = 'flex';
    setTimeout(initCanvas, 100);
};

window.closeSignatureModal = function() { 
    document.getElementById('sigModal').style.display = 'none'; 
    if(window.currentSyncSid && window.currentSyncUser) {
        firebase.database().ref(`MASTER_ADMIN_DB/structures_data/${window.currentSyncSid}/device_sync/${window.currentSyncUser}`).remove();
    }
};

window.clearCanvas = function() { if(sigCtx) sigCtx.clearRect(0, 0, sigCanvas.width, sigCanvas.height); };

window.uploadSignature = function() {
    const btn = document.getElementById('btnSendSig'); 
    btn.innerText = 'CARICAMENTO...'; btn.disabled = true;
    const base64 = sigCanvas.toDataURL();
    
    fetch(MAKE_WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
            appId: window.currentSyncAppId, 
            image: base64, 
            now: new Date().toLocaleString('it-IT')
        })
    }).then(res => res.json()).then(data => {
        firebase.database().ref(`MASTER_ADMIN_DB/structures_data/${window.currentSyncSid}/device_sync/${window.currentSyncUser}`).update({
            status: 'completed', 
            driveLink: data.fileUrl || data.url
        });
        document.getElementById('sigModal').style.display = 'none';
        btn.innerHTML = '<i class="material-icons-round">cloud_upload</i> SALVA PDF'; btn.disabled = false;
        showToast("PDF Generato!");
    }).catch(err => {
        alert('Errore webhook. Controlla Make.');
        btn.innerHTML = '<i class="material-icons-round">cloud_upload</i> SALVA PDF'; btn.disabled = false;
    });
};
</script>
</body>
</html>